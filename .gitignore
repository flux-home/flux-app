app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Local machine config — never commit
android/local.properties
android/key.properties

# Real CHIP SDK AAR — not tracked, obtain via android/get_chip_sdk.sh
android/app/libs/CHIPController.aar

# Real CHIP SDK xcframework — not tracked, obtain via ios/get_chip_sdk_ios.sh
ios/Frameworks/Matter.xcframework

# Signing keystore — never commit
android/app/keystore.jks
android/key.properties

# Local build/workaround artifacts (not part of the build)
classes.jar
.ld-workaround
ld_workaround

# Local agent / tool state
.antigravitycli/
.agents/REVIEW_PLAN.md
.claude/

# Stale build artifacts
/chip/
